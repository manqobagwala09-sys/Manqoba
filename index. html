<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Keno Style Generator</title>
<link rel="stylesheet" href="style.css">
</head>

<body>

<div class="container">

<h1>🎮 Keno Weighted Generator</h1>

<p class="subtitle">Select up to 20 numbers (1–80)</p>

<div id="grid"></div>

<div class="controls">
    <button onclick="generateResult()">Generate Draw</button>
    <button onclick="resetAll()">Reset</button>
</div>

<div class="panel">
    <h2>Result</h2>
    <div id="result">Waiting...</div>
</div>

</div>

<script src="script.js"></script>
</body>
</html>
