let selected = [];

const grid = document.getElementById("grid");

// create 1–80 grid
for (let i = 1; i <= 80; i++) {
    let div = document.createElement("div");
    div.classList.add("number");
    div.innerText = i;

    div.onclick = () => toggle(i, div);

    grid.appendChild(div);
}

function toggle(num, el) {
    if (selected.includes(num)) {
        selected = selected.filter(n => n !== num);
        el.classList.remove("selected");
    } else {
        if (selected.length >= 20) {
            alert("Max 20 numbers allowed");
            return;
        }
        selected.push(num);
        el.classList.add("selected");
    }
}

// weighted generator
function generateResult() {
    if (selected.length !== 20) {
        alert("Please select exactly 20 numbers");
        return;
    }

    let pool = [];

    // high weight
    selected.forEach(n => {
        for (let i = 0; i < 6; i++) {
            pool.push(n);
        }
    });

    // low weight others
    for (let i = 1; i <= 80; i++) {
        if (!selected.includes(i)) {
            pool.push(i);
        }
    }

    let result = pool[Math.floor(Math.random() * pool.length)];

    document.getElementById("result").innerText = result;
}

// reset system
function resetAll() {
    selected = [];
    document.querySelectorAll(".number").forEach(el => {
        el.classList.remove("selected");
    });
    document.getElementById("result").innerText = "Waiting...";
}
